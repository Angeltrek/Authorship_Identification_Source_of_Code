 0.9109     0.9175  0.9109      NaN\n              TF-IDF + MLP    0.6986    0.7075     0.7370  0.6986      NaN\n   TF-IDF+KNN (referencia)    0.6213       NaN        NaN     NaN      NaN\n          Characters + MLP    0.6187    0.6154     0.6628  0.6187      NaN\nCharacters+LR (referencia)    0.2925       NaN        NaN     NaN      NaN\n       Random (referencia)    0.0010       NaN        NaN     NaN      NaN\n        AST features + MLP    0.0010    0.0000     0.0000  0.0010      NaN\n===========================================================================\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x500 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":32},{"id":"c67c830a-3944-489f-a99c-7bb0102ea8c9","cell_type":"markdown","source":"## Accuracy por número de ejemplos de entrenamiento por autor\n\nSe analiza si los modelos funcionan mejor para autores con más ejemplos en el conjunto de entrenamiento. \nEsto permite entender las limitaciones reales del sistema: \nsi la accuracy cae mucho para autores con pocos ejemplos, \nel modelo no generalizará bien a autores poco representados.","metadata":{}},{"id":"4a756649-78c9-4dd3-ac45-413113fb260d","cell_type":"code","source":"author_counts = train_df['uid'].value_counts()\n\ndef accuracy_by_group(y_true, y_pred, author_counts, bins=[0,5,10,20,50,10000]):\n    df = pd.DataFrame({'uid': y_true, 'pred': y_pred})\n    df['n_train'] = df['uid'].map(author_counts)\n    df['correct'] = df['uid'] == df['pred']\n    df['group']   = pd.cut(df['n_train'], bins=bins,\n                           labels=[f'{bins[i]+1}-{bins[i+1]}' for i in range(len(bins)-1)])\n    return df.groupby('group', observed=True)['correct'].mean()\n\n\nfig, ax = plt.subplots(figsize=(10, 4))\nfor name, y_pred in [\n    ('Characters+MLP',          y_pred_chars),\n    ('TF-IDF+MLP',              y_pred_tfidf),\n    ('TF-IDF char ngram+MLP',   y_pred_char),\n    ('AST features+MLP',         y_pred_ast),\n]:\n    acc_by_group = accuracy_by_group(y_dev_labels, y_pred, author_counts)\n    ax.plot(acc_by_group.index, acc_by_group.values, marker='o', label=name)\n\nax.set_title('Accuracy por número de ejemplos de entrenamiento por autor')\nax.set_xlabel('Ejemplos de entrenamiento por autor')\nax.set_ylabel('Accuracy')\nax.legend()\nax.grid(True, alpha=0.4)\nplt.tight_layout()\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T16:03:45.547008Z","iopub.execute_input":"2026-04-29T16:03:45.547382Z","iopub.status.idle":"2026-04-29T16:03:45.710924Z","shell.execute_reply.started":"2026-04-29T16:03:45.547357Z","shell.execute_reply":"2026-04-29T16:03:45.710290Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x400 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":33},{"id":"c06687a5-3a63-4450-8725-b39156ddb318","cell_type":"markdown","source":"## Predicción sobre código nuevo\n\nLa función recibe un fragmento de código y lo clasifica con los tres modelos entrenados. \nDevuelve el autor predicho y la probabilidad de la predicción para cada modelo.","metadata":{}},{"id":"ede4248d-cced-4f04-9956-8b574b223082","cell_type":"code","source":"def predict_author(source_code):\n    chars   = char_count_vectorize([source_code])\n    tfidf_w_vec = tfidf_w.transform([source_code]).toarray().astype(np.float32)\n    tfidf_c_vec = tfidf_c.transform([source_code]).toarray().astype(np.float32)\n\n    print('='*58)\n    print(f'Código ({len(source_code)} chars):')\n    print(source_code[:120].replace('\\n', ' '))\n    print('-'*58)\n\n    for name, model, X in [\n        ('Characters + MLP',        model_chars, chars),\n        ('TF-IDF + MLP',            model_tfidf, tfidf_w_vec),\n        ('TF-IDF char n-gramas+MLP', model_char,  tfidf_c_vec),\n    ]:\n        probs = model.predict(X, verbose=0)[0]\n        pred_idx = np.argmax(probs)\n        pred_uid = le.inverse_transform([pred_idx])[0]\n        conf     = probs[pred_idx] * 100\n        print(f'  {name:30s}: UID {pred_uid:4d}  ({conf:.1f}% confianza)')\n    print('='*58)\n\n\nexample = '''\n#include <iostream>\nusing namespace std;\nint main() {\n    int n;\n    cin >> n;\n    cout << n * 2 << endl;\n    return 0;\n}\n'''\npredict_author(example)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T16:03:45.711903Z","iopub.execute_input":"2026-04-29T16:03:45.712340Z","iopub.status.idle":"2026-04-29T16:03:46.956634Z","shell.execute_reply.started":"2026-04-29T16:03:45.712306Z","shell.execute_reply":"2026-04-29T16:03:46.955798Z"}},"outputs":[{"name":"stdout","text":"==========================================================\nCódigo (123 chars):\n #include <iostream> using namespace std; int main() {     int n;     cin >> n;     cout << n * 2 << endl;     return 0;\n----------------------------------------------------------\n  Characters + MLP              : UID  896  (1.7% confianza)\n  TF-IDF + MLP                  : UID  687  (3.0% confianza)\n  TF-IDF char n-gramas+MLP      : UID  643  (65.2% confianza)\n==========================================================\n","output_type":"stream"}],"execution_count":34}]}
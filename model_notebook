des_df, on='pid', how='left')\n\n    loaded = df_merged['source_code'].notna().sum()\n    print(f'{base_path.split(\"/\")[-1]}: {loaded:,} / {len(df_merged):,} códigos cargados')\n    return df_merged\n\n\ntrain_df = load_source_codes(train_df, os.path.join(os.path.abspath(REPO_DIR), 'data_dir', 'train'))\ndev_df   = load_source_codes(dev_df,   os.path.join(os.path.abspath(REPO_DIR), 'data_dir', 'dev'))\ntest_df  = load_source_codes(test_df,  os.path.join(os.path.abspath(REPO_DIR), 'data_dir', 'test'))\n\ntrain_df = train_df.dropna(subset=['source_code'])\ndev_df   = dev_df.dropna(subset=['source_code'])\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T21:12:31.218330Z","iopub.execute_input":"2026-04-29T21:12:31.218554Z","iopub.status.idle":"2026-04-29T21:12:34.886268Z","shell.execute_reply.started":"2026-04-29T21:12:31.218533Z","shell.execute_reply":"2026-04-29T21:12:34.885495Z"}},"outputs":[{"name":"stdout","text":"train: 50,000 / 50,000 códigos cargados\ndev: 25,000 / 25,000 códigos cargados\ntest: 25,000 / 25,000 códigos cargados\n","output_type":"stream"}],"execution_count":5},{"id":"78eb29c8-a311-48fb-a666-c04690f42723","cell_type":"markdown","source":"## Análisis exploratorio\n\nSe analizan seis dimensiones del dataset: distribución de ejemplos por autor, \nlongitud total del código en caracteres, número de líneas, longitud promedio de línea, \nlos autores más representados y la relación entre líneas y caracteres totales. \nLa longitud promedio de línea y el número de líneas son features implícitos del estilo de programación: \nalgunos autores tienden a escribir líneas cortas y separar la lógica, \notros escriben expresiones densas en pocas líneas. \nEstos patrones son los que los modelos intentarán capturar.","metadata":{}},{"id":"25bfd0de-d3d8-4284-a0a0-cdfa76d6e145","cell_type":"code","source":"samples_per_author = train_df['uid'].value_counts()\ntrain_df['code_length'] = train_df['source_code'].str.len()\ntrain_df['line_count']  = train_df['source_code'].str.count('\\n')\ntrain_df['avg_line_len'] = train_df['code_length'] / (train_df['line_count'] + 1)\n\nfig, axes = plt.subplots(2, 3, figsize=(16, 9))\n\n# 1. Ejemplos por autor\naxes[0,0].hist(samples_per_author.values, bins=30, color='steelblue', edgecolor='white')\naxes[0,0].set_title('Ejemplos por autor')\naxes[0,0].set_xlabel('Número de ejemplos')\naxes[0,0].set_ylabel('Autores')\n\n# 2. Longitud de código\naxes[0,1].hist(train_df['code_length'].clip(upper=5000), bins=50,\n               color='steelblue', edgecolor='white')\naxes[0,1].set_title('Longitud del código (chars, truncada a 5000)')\naxes[0,1].set_xlabel('Caracteres')\n\n# 3. Número de líneas\naxes[0,2].hist(train_df['line_count'].clip(upper=200), bins=50,\n               color='steelblue', edgecolor='white')\naxes[0,2].set_title('Número de líneas (truncado a 200)')\naxes[0,2].set_xlabel('Líneas')\n\n# 4. Longitud promedio de línea\naxes[1,0].hist(train_df['avg_line_len'].clip(upper=100), bins=50,\n               color='steelblue', edgecolor='white')\naxes[1,0].set_title('Longitud promedio de línea')\naxes[1,0].set_xlabel('Chars / línea')\n\n# 5. Top 20 autores con más ejemplos\ntop20 = samples_per_author.head(20)\naxes[1,1].barh(top20.index.astype(str), top20.values, color='steelblue')\naxes[1,1].set_title('Top 20 autores con más ejemplos')\naxes[1,1].set_xlabel('Ejemplos')\naxes[1,1].invert_yaxis()\n\n# 6. Longitud de código vs número de líneas (muestra)\nsample = train_df.sample(2000, random_state=42)\naxes[1,2].scatter(sample['line_count'].clip(upper=200),\n                  sample['code_length'].clip(upper=5000),\n                  alpha=0.3, s=5, color='steelblue')\naxes[1,2].set_title('Líneas vs longitud total (muestra 2k)')\naxes[1,2].set_xlabel('Líneas')\naxes[1,2].set_ylabel('Caracteres')\n\nplt.suptitle('Análisis exploratorio — AI-SOCO', fontsize=14, fontweight='bold')\nplt.tight_layout()\nplt.show()\n\nprint(f'Ejemplos por autor — media: {samples_per_author.mean():.1f}  '\n      f'min: {samples_per_author.min()}  max: {samples_per_author.max()}')\nprint(f'Longitud — media: {train_df[\"code_length\"].mean():.0f}  '\n      f'mediana: {train_df[\"code_length\"].median():.0f} chars')\nprint(f'Líneas   — media: {train_df[\"line_count\"].mean():.1f}  '\n      f'mediana: {train_df[\"line_count\"].median():.0f}')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T21:12:34.887289Z","iopub.execute_input":"2026-04-29T21:12:34.887599Z","iopub.status.idle":"2026-04-29T21:12:36.246837Z","shell.execute_reply.started":"2026-04-29T21:12:34.887575Z","shell.execute_reply":"2026-04-29T21:12:36.245979Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x900 with 6 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Ejemplos por autor — media: 50.0  min: 50  max: 50\nLongitud — media: 1646  mediana: 1166 chars\nLíneas   — media: 73.8  mediana: 58\n","output_type":"stream"}],"execution_count":6},{"id":"7a657ecb-bb57-45d8-bd9f-879a9eccc983","cell_type":"markdown","source":"## Guardado, carga de modelos y evaluación\n\nLos modelos de Keras usan los mismos callbacks que en el repositorio SongTextClassifier: \nModelCheckpoint guarda el mejor modelo según val_loss, EarlyStopping detiene el entrenamiento \nsi no hay mejora y ReduceLROnPlateau reduce el learning rate cuando el modelo se estanca. \nSi el archivo del modelo ya existe en disco se carga directamente sin reentrenar, \npermitiendo retomar el trabajo entre sesiones.\n\nLos vectorizadores TF-IDF se guardan con joblib porque no son modelos de Keras. \nSe ajustan solo sobre el conjunto de entrenamiento para evitar filtrar información del dev al modelo.","metadata":{}},{"id":"a415c0a2-41fe-4514-8ccb-7688af3ada9b","cell_type":"code","source":"results = {}\n\ndef get_callbacks(model_name):\n    return [\n        ModelCheckpoint(\n            filepath=MODEL_PATH + f'{model_name}.keras',\n            monitor='val_loss',\n            save_best_only=True,\n            mode='min',\n            verbose=1\n        ),\n        EarlyStopping(\n            monitor='val_loss',\n            patience=5,\n            restore_best_weights=True,\n            verbose=1\n        ),\n        ReduceLROnPlateau(\n            monitor='val_loss',\n            factor=0.5,\n            patience=3,\n            min_lr=1e-7,\n            verbose=1\n        )\n    ]\n\n\ndef load_keras_if_exists(model_name):\n    path = MODEL_PATH + f'{model_name}.keras'\n    if os.path.exists(path):\n        print(f'Modelo cargado desde disco: {model_name}')\n        return load_model(path)\n    return None\n\n\ndef save_vectorizer(name, vec):\n    joblib.dump(vec, MODEL_PATH + f'{name}_vectorizer.joblib')\n    print(f'Vectorizador guardado: {name}_vectorizer.joblib')\n\n\ndef load_vectorizer_if_exists(name):\n    path = MODEL_PATH + f'{name}_vectorizer.joblib'\n    if os.path.exists(path):\n        print(f'Vectorizador cargado: {name}_vectorizer.joblib')\n        return joblib.load(path)\n    return None\n\n\ndef evaluate(name, y_true, y_pred, training_time=None):\n    acc       = accuracy_score(y_true, y_pred)\n    f1_macro  = f1_score(y_true, y_pred, average='macro',    zero_division=0)\n    f1_weight = f1_score(y_true, y_pred, average='weighted', zero_division=0)\n    prec      = precision_score(y_true, y_pred, average='macro', zero_division=0)\n    rec       = recall_score(y_true, y_pred, average='macro',    zero_division=0)\n    results[name] = {\n        'Accuracy':    round(acc,       4),\n        'F1 Macro':    round(f1_macro,  4),\n        'F1 Weighted': round(f1_weight, 4),\n        'Precision':   round(prec,      4),\n        'Recall':      round(rec,       4),\n        'Time(s)':     round(training_time, 2) if training_time else None\n    }\n    print(f'\\n{\"=\"*55}\\n  {name}\\n{\"=\"*55}')\n    print(f'  Accuracy:    {acc:.4f}  ({acc*100:.2f}%)')\n    print(f'  F1 Macro:    {f1_macro:.4f}')\n    print(f'  F1 Weighted: {f1_weight:.4f}')\n    print(f'  Precision:   {prec:.4f}')\n    print(f'  Recall:      {rec:.4f}')\n    if training_time:\n        print(f'  Tiempo:      {training_time:.2f}s')\n    return acc\n\n\ndef plot_full_cm(name, y_true, y_pred):\n    labels = sorted(set(y_true))\n    cm = confusion_matrix(y_true, y_pred, labels=labels)\n    plt.figure(figsize=(10, 8))\n    plt.imshow(cm, aspect='auto', cmap='Blues', interpolation='nearest')\n    plt.colorbar(label='Predicciones')\n    plt.title(f'Matriz de confusión completa ({len(labels)} autores) — {name}')\n    plt.xlabel('Predicción (uid)')\n    plt.ylabel('Real (uid)')\n    plt.tight_layout()\n    plt.show()\n    diag     = np.diag(cm)\n    row_sums = cm.sum(axis=1)\n    pca      = np.where(row_sums > 0, diag / row_sums, 0)\n    print(f'  Autores con acc = 1.0:  {(pca == 1.0).sum()}')\n    print(f'  Autores con acc = 0.0:  {(pca == 0.0).sum()}')\n    print(f'  Accuracy media por clase: {pca.mean():.4f}')\n\n\ndef plot_per_class_acc_hist(name, y_true, y_pred):\n    labels   = sorted(set(y_true))\n    cm       = confusion_matrix(y_true, y_pred, labels=labels)\n    diag     = np.diag(cm)\n    row_sums = cm.sum(axis=1)\n    pca      = np.where(row_sums > 0, diag / row_sums, 0)\n    plt.figure(figsize=(9, 4))\n    plt.hist(pca, bins=20, color='steelblue', edgecolor='white')\n    plt.axvline(pca.mean(), color='#e74c3c', linestyle='--',\n                label=f'Media: {pca.mean():.3f}')\n    plt.title(f'Distribución de accuracy por autor — {name}')\n    plt.xlabel('Accuracy individual del autor')\n    plt.ylabel('Número de autores')\n    plt.legend()\n    plt.tight_layout()\n    plt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T21:12:36.247784Z","iopub.execute_input":"2026-04-29T21:12:36.248225Z","iopub.status.idle":"2026-04-29T21:12:36.262288Z","shell.execute_reply.started":"2026-04-29T21:12:36.248186Z","shell.execute_reply":"2026-04-29T21:12:36.261529Z"}},"outputs":[],"execution_count":7},{"id":"0198d0f7-96f0-4969-a85d-c99644656d89","cell_type":"markdown","source":"## Modelo base — Characters Count + MLP\n\nEl baseline del repositorio usa conteo de caracteres con regresión logística. \nAquí se reemplaza el clasificador por una red neuronal densa que corre en GPU. \nLa vectorización es idéntica: un vector de 100 dimensiones con la frecuencia de cada carácter ASCII imprimible. \nLa red aprende combinaciones no lineales de esas frecuencias, \nlo que permite capturar patrones de estilo más sutiles que la combinación lineal de la regresión logística. \nEl repositorio reporta 29.252% de accuracy con Characters+LR, \nlo que sirve como piso de referencia para este modelo.","metadata":{}},{"id":"25eb1dbd-4d74-407d-93bf-2e3f5ca97c71","cell_type":"code","source":"PRINTABLE = list(string.printable)\n\ndef char_count_vectorize(texts):\n    matrix = np.zeros((len(texts), len(PRINTABLE)), dtype=np.float32)\n    for i, text in enumerate(texts):\n        for j, ch in enumerate(PRINTABLE):\n            matrix[i, j] = text.count(ch)\n    return matrix\n\n\nle = LabelEncoder()\nle.fit(train_df['uid'])\ny_train    = le.transform(train_df['uid'])\ny_dev      = le.transform(dev_df['uid'])\nnum_classes = len(le.classes_)\n\nX_train_chars = char_count_vectorize(train_df['source_code'].tolist())\nX_dev_chars   = char_count_vectorize(dev_df['source_code'].tolist())\n\nmodel_chars = load_keras_if_exists('chars_mlp')\n\nif model_chars is None:\n    model_chars = Sequential([\n        Dense(256, activation='relu', input_shape=(len(PRINTABLE),)),\n        BatchNormalization(),\n        Dropout(0.4),\n        Dense(128, activation='relu'),\n        BatchNormalization(),\n        Dropout(0.3),\n        Dense(num_classes, activation='softmax')\n    ], name='chars_mlp')\n    model_chars.compile(\n        optimizer=Adam(learning_rate=1e-3),\n        loss='sparse_categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    model_chars.summary()\n    t0 = time.time()\n    model_chars.fit(\n        X_train_chars, y_train,\n        validation_data=(X_dev_chars, y_dev),\n        epochs=30,\n        batch_size=256,\n        callbacks=get_callbacks('chars_mlp'),\n        verbose=1\n    )\n    t1 = time.time()\nelse:\n    t0 = t1 = time.time()\n\ny_pred_chars = le.inverse_transform(\n    np.argmax(model_chars.predict(X_dev_chars, verbose=0), axis=1)\n)\ny_dev_labels = le.inverse_transform(y_dev)\n\nevaluate('Characters + MLP', y_dev_labels, y_pred_chars,\n         t1 - t0 if t1 > t0 else None)\nplot_full_cm('Characters + MLP', y_dev_labels, y_pred_chars)\nplot_per_class_acc_hist('Characters + MLP', y_dev_labels, y_pred_chars)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T21:12:36.263332Z","iopub.execute_input":"2026-04-29T21:12:36.263589Z","iopub.status.idle":"2026-04-29T21:13:20.809826Z","shell.execute_reply.started":"2026-04-29T21:12:36.263560Z","shell.execute_reply":"2026-04-29T21:13:20.809217Z"}},"outputs":[{"name":"stderr","text":"I0000 00:00:1777497164.600490      57 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 13757 MB memory:  -> device: 0, name: Tesla T4, pci bus id: 0000:00:04.0, compute capability: 7.5\nI0000 00:00:1777497164.606407      57 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:1 with 13757 MB memory:  -> device: 1, name: Tesla T4, pci bus id: 0000:00:05.0, compute capability: 7.5\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"chars_mlp\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"chars_mlp\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)                   \u001b[0m\
{}}],"execution_count":15},{"id":"36bafbae-81d2-4ca4-ac59-6ff4784d2768","cell_type":"markdown","source":"## Comparación de modelos\n\nSe comparan los tres modelos junto con los baselines reportados en el repositorio original. \nLos valores de referencia son: random baseline ~0.1%, Characters+LR 29.252%, TF-IDF+KNN 62.128%.","metadata":{}},{"id":"7076fbff-5065-4a98-9723-ec24a6386420","cell_type":"code","source":"baselines = {\n    'Random (referencia)':        {'Accuracy':0.0010,'F1 Macro':None,'F1 Weighted':None,'Precision':None,'Recall':None,'Time(s)':None},\n    'Characters+LR (referencia)': {'Accuracy':0.2925,'F1 Macro':None,'F1 Weighted':None,'Precision':None,'Recall':None,'Time(s)':None},\n    'TF-IDF+KNN (referencia)':    {'Accuracy':0.6213,'F1 Macro':None,'F1 Weighted':None,'Precision':None,'Recall':None,'Time(s)':None},\n}\nall_results = {**baselines, **results}\n\ndf_res = pd.DataFrame(all_results).T.reset_index()\ndf_res.columns = ['Modelo','Accuracy','F1 Macro','F1 Weighted','Precision','Recall','Time(s)']\ndf_res['Accuracy'] = df_res['Accuracy'].astype(float)\ndf_res = df_res.sort_values('Accuracy', ascending=False).reset_index(drop=True)\n\nprint('='*75)\nprint('COMPARATIVA — AI-SOCO Authorship Attribution')\nprint('='*75)\nprint(df_res[['Modelo','Accuracy','F1 Macro','Precision','Recall','Time(s)']].to_string(index=False))\nprint('='*75)\n\nmetrics = ['Accuracy','F1 Macro','Precision','Recall']\ndf_plot = df_res.dropna(subset=['F1 Macro'])\n\nfig, axes = plt.subplots(1, 4, figsize=(20, 5))\ncolors = plt.cm.tab10(np.linspace(0, 1, len(df_plot)))\n\nfor ax, metric in zip(axes, metrics):\n    vals = df_plot[metric].astype(float)\n    bars = ax.barh(df_plot['Modelo'], vals, color=colors)\n    ax.set_title(metric)\n    ax.set_xlim(0, 1.0)\n    ax.invert_yaxis()\n    if metric == 'Accuracy':\n        ax.axvline(0.6213, color='#e74c3c', linestyle='--', linewidth=1,\n                   label='TF-IDF+KNN ref (62.13%)')\n        ax.axvline(0.2925, color='#e67e22
ata":{}}],"execution_count":17},{"id":"b2d85dab-ae4a-4b8b-8c98-f75b081e6d8b","cell_type":"markdown","source":"## Predicción sobre código nuevo\n\nLa función recibe un fragmento de código y lo clasifica con los tres modelos entrenados. \nDevuelve el autor predicho y la probabilidad de la predicción para cada modelo.","metadata":{}},{"id":"c540dd58-1a96-4073-9268-d477bfc32f86","cell_type":"code","source":"def predict_author(source_code):\n    \"\"\"\n    Predice el autor de un fragmento de código usando los cinco modelos entrenados.\n    \"\"\"\n    chars     = char_count_vectorize([source_code])\n    tfidf_w_v = tfidf_w.transform([source_code]).toarray().astype('float32')\n    tfidf_c_v = tfidf_c.transform([source_code]).toarray().astype('float32')\n    ast_feats = extract_ast_features(source_code)\n    ast_vec   = np.array([[ast_feats.get(k, 0) for k in ast_vocab_m4]], dtype='float32')\n    tfidf_c_comb_v = tfidf_c_combined.transform([source_code]).toarray().astype('float32')\n    combined_v = np.concatenate([tfidf_c_comb_v, ast_vec], axis=1)\n\n    print('=' * 62)\n    print(f'Código ({len(source_code)} chars):')\n    print(source_code[:120].replace('\\n', ' '))\n    print('-' * 62)\n\n    for name, model, X in [\n        ('Characters + MLP',           model_chars,    chars),\n        ('TF-IDF + MLP',               model_tfidf,    tfidf_w_v),\n        ('TF-IDF char n-gramas + MLP', model_char,     tfidf_c_v),\n        ('AST features + MLP',         model_ast,      ast_vec),\n        ('AST + TF-IDF char + MLP',    model_combined, combined_v),\n    ]:\n        probs    = model.predict(X, verbose=0)[0]\n        pred_idx = np.argmax(probs)\n        pred_uid = le.inverse_transform([pred_idx])[0]\n        conf     = probs[pred_idx] * 100\n        bar      = chr(9608) * int(conf / 5)\n        print(f'  {name:35s}: UID {pred_uid:4d}  ({conf:.1f}%) {bar}')\n    print('=' * 62)\n\n\nexample1 = '''\n#include <iostream>\nusing namespace std;\nint main() {\n    int n;\n    cin 
% de accuracy con TF-IDF+KNN como punto de referencia.","metadata":{}},{"id":"dc13424f-5d50-4525-9b73-ae39f4c52b00","cell_type":"code","source":"tfidf_w = load_vectorizer_if_exists('tfidf_word')\n\nif tfidf_w is None:\n    tfidf_w = TfidfVectorizer(max_features=10000)\n    X_train_tfidf = tfidf_w.fit_transform(train_df['source_code'].astype(str))\n    save_vectorizer('tfidf_word', tfidf_w)\nelse:\n    X_train_tfidf = tfidf_w.transform(train_df['source_code'].astype(str))\n\nX_dev_tfidf = tfidf_w.transform(dev_df['source_code'].astype(str))\n\n# Convertir a denso en batches para no saturar RAM\nBATCH = 5000\n\ndef sparse_to_dense_batched(X):\n    parts = []\n    for start in range(0, X.shape[0], BATCH):\n        parts.append(X[start:start+BATCH].toarray().astype(np.float32))\n    return np.vstack(parts)\n\n\nX_train_tfidf_d = sparse_to_dense_batched(X_train_tfidf)\nX_dev_tfidf_d   = sparse_to_dense_batched(X_dev_tfidf)\nprint(f'Train: {X_train_tfidf_d.shape}  Dev: {X_dev_tfidf_d.shape}')\n\nmodel_tfidf = load_keras_if_exists('tfidf_mlp')\n\nif model_tfidf is None:\n    model_tfidf = Sequential([\n        Dense(512, activation='relu', input_shape=(X_train_tfidf_d.shape[1],)),\n        BatchNormalization(),\n        Dropout(0.4),\n        Dense(256, activation='relu'),\n        BatchNormalization(),\n        Dropout(0.3),\n        Dense(128, activation='relu'),\n        Dropout(0.2),\n        Dense(num_classes, activation='softmax')\n    ], name='tfidf_mlp')\n    model_tfidf.compile(\n        optimizer=Adam(learning_rate=1e-3),\n        loss='sparse_categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    model_tfidf.summary()\n    t0 = time.time()\n    model_tfidf.fit(\n        X_train_tfidf_d, y_train,\n        validation_data=(X_dev_tfidf_d, y_dev),\n        epochs=30,\n        batch_size=256,\n        callbacks=get_callbacks('tfidf_mlp'),\n        verbose=1\n    )\n    t1 = time.time()\nelse:\n    t0 = t1 = time.time()\n\ny_pred_tfidf = le.inverse_transform(\n    np.argmax(model_tfidf.predict(X_dev_tfidf_d, verbose=0), axis=1)\n)\n\nevaluate('TF-IDF + MLP', y_dev_labels, y_pred_tfidf,\n         t1 - t0 if t1 > t0 else None)\nplot_full_cm('TF-IDF + MLP', y_dev_labels, y_pred_tfidf)\nplot_per_class_acc_hist('TF-IDF + MLP', y_dev_labels, y_pred_tfidf)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T21:13:20.810672Z","iopub.execute_input":"2026-04-29T21:13:20.810921Z","iopub.status.idle":"2026-04-29T21:14:37.631312Z","shell.execute_reply.started":"2026-04-29T21:13:20.810898Z","shell.execute_reply":"2026-04-29T21:14:37.630629Z"}},"outputs":[{"name":"stdout","text":"Vectorizador guardado: tfidf_word_vectorizer.joblib\nTrain: (50000, 10000)  Dev: (25000, 10000)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"tfidf_mlp\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"tfidf_mlp\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)                   \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape          \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m      Param #\u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━┩\n│ dense_3 (\u001b[38;5;33mDense\u001b[0m)                 │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m512\u001b[0m)            │     \u001b[38;5;34m5,120,512\u001b[0m │\n├─────────────────────────────────┼────────────────────────┼───────────────┤\n│ batch_normalization_2           │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m512\u001b[0m)            │         \u001b[38;5;34m2,048\u001b[0m │\n│ (\u001b[38;5;33mBatchNormalization\u001b[0m)  
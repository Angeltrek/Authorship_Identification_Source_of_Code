 vocabulario o los n-gramas. La comparación con los modelos TF-IDF permite cuantificar qué aporta la estructura lógica respecto al análisis textual.","metadata":{}},{"id":"5d287f58-7b4b-415c-a26d-b3065964de59","cell_type":"code","source":"X_ast_dev, _ = ast_vectorize(dev_df['source_code'].tolist(), vocab=ast_vocab)\n\nmodel_ast = load_keras_if_exists('ast_mlp')\n\nif model_ast is None:\n    model_ast = Sequential([\n        Dense(256, activation='relu', input_shape=(X_ast_train.shape[1],)),\n        BatchNormalization(),\n        Dropout(0.4),\n        Dense(128, activation='relu'),\n        BatchNormalization(),\n        Dropout(0.3),\n        Dense(num_classes, activation='softmax')\n    ], name='ast_mlp')\n    model_ast.compile(\n        optimizer=Adam(learning_rate=1e-3),\n        loss='sparse_categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    model_ast.summary()\n    t0 = time.time()\n    model_ast.fit(\n        X_ast_train, y_train,\n        validation_data=(X_ast_dev, y_dev),\n        epochs=30,\n        batch_size=256,\n        callbacks=get_callbacks('ast_mlp'),\n        verbose=1\n    )\n    t1 = time.time()\nelse:\n    t0 = t1 = time.time()\n\ny_pred_ast = le.inverse_transform(\n    np.argmax(model_ast.predict(X_ast_dev, verbose=0), axis=1)\n)\n\nevaluate('AST features + MLP', y_dev_labels, y_pred_ast,\n         t1 - t0 if t1 > t0 else None)\nplot_full_cm('AST features + MLP', y_dev_labels, y_pred_ast)\nplot_per_class_acc_hist('AST features + MLP', y_dev_labels, y_pred_ast)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T17:00:14.080079Z","iopub.execute_input":"2026-04-29T17:00:14.080590Z","iopub.status.idle":"2026-04-29T17:01:15.195431Z","shell.execute_reply.started":"2026-04-29T17:00:14.080564Z","shell.execute_reply":"2026-04-29T17:01:15.194804Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"ast_mlp\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;li